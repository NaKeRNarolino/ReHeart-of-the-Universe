        "uv": {
          "texture_width": 16,
          "texture_height": 16,
          "uv": [4, 2],
          "uv_size": [4, 4]
        }
      },
      "minecraft:particle_appearance_tinting": {
        "color": [
          "v.color_red ?? 1.0",
          "v.color_green ?? 0.8",
          "v.color_blue ?? 0.45",
          "v.particle_lifetime - v.particle_age"
        ]
      }
    }
